<?xml version="1.0" encoding="utf-8"?>
<!-- Manus-style bottom-sheet connectors panel.
     Shows ALL 11 services as horizontal rows: [icon] [name + status] [Connect/Toggle].
     Slides up from the bottom with a fade. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/connected_apps_panel"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:maxHeight="520dp"
    android:orientation="vertical"
    android:background="@drawable/manus_panel_bg"
    android:elevation="24dp"
    android:clipToOutline="true"
    android:paddingTop="10dp"
    android:paddingBottom="14dp">

    <!-- Drag handle (Manus-style pill) -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/drag_handle_pill"
        android:layout_marginBottom="10dp" />

    <!-- Header: title + count + close -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="12dp"
        android:paddingBottom="10dp">

        <TextView
            android:id="@+id/tv_panel_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Connectors"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_connected_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#71717A"
            android:textSize="12sp"
            android:layout_marginEnd="14dp" />

        <ImageView
            android:id="@+id/btn_close_connected_apps"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="#71717A"
            android:padding="4dp"
            android:scaleType="fitCenter" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1AFFFFFF"
        android:layout_marginBottom="4dp" />

    <!-- Services list (rows are added programmatically) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fadeScrollbars="true"
        android:scrollbars="vertical">

        <LinearLayout
            android:id="@+id/connected_apps_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <!-- Empty state -->
    <TextView
        android:id="@+id/tv_no_connected"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No connectors available."
        android:textColor="#52525B"
        android:textSize="12sp"
        android:gravity="center"
        android:padding="16dp"
        android:visibility="gone" />

</LinearLayout>
