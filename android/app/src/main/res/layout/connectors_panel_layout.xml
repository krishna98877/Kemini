<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/connectors_panel"
    android:layout_width="300dp"
    android:layout_height="460dp"
    android:orientation="vertical"
    android:background="@drawable/glass_panel_bg"
    android:elevation="8dp"
    android:clipToOutline="true">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="18dp"
        android:paddingBottom="12dp"
        android:background="#10000000">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_connectors"
            android:tint="#00F6FF"
            android:layout_marginEnd="10dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Automations"
            android:textColor="#ffffff"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.3" />

        <TextView
            android:id="@+id/tv_composio_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Not connected"
            android:textColor="#6B7280"
            android:textSize="11sp"
            android:layout_marginEnd="12dp" />

        <ImageView
            android:id="@+id/btn_close_connectors"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="#6B7280"
            android:padding="4dp"
            android:contentDescription="Close"
            android:scaleType="fitCenter" />
    </LinearLayout>

    <!-- Composio connect banner (shown when not configured) -->
    <LinearLayout
        android:id="@+id/composio_connect_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/glass_input_bg"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_composio"
            android:tint="#00F6FF"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Connect Composio to enable automations"
            android:textColor="#aaaaaa"
            android:textSize="12sp" />

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_arrow_right"
            android:tint="#00F6FF" />
    </LinearLayout>

    <!-- Scrollable services list -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fadeScrollbars="false"
        android:scrollbars="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:id="@+id/services_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

</LinearLayout>