<?xml version="1.0" encoding="utf-8"?>
<!-- Premium bubble background: subtle glow halo + cyan ring + dark center -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer glow halo (subtle, fits within View) -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#153A5C"/>
            <size android:width="68dp" android:height="68dp"/>
        </shape>
    </item>

    <!-- Cyan ring -->
    <item
        android:top="1dp" android:bottom="1dp"
        android:left="1dp" android:right="1dp">
        <shape android:shape="oval">
            <stroke
                android:width="2dp"
                android:color="#23A6E2"/>
            <solid android:color="#080808"/>
            <size android:width="66dp" android:height="66dp"/>
        </shape>
    </item>

</layer-list>
